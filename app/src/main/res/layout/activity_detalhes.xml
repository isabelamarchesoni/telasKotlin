<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8">

    <ImageView
        android:id="@+id/img_livro"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/book"
        app:tint="#4E342E"
        android:contentDescription="Ícone de livro"
        android:layout_marginTop="160dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_titulo_pagina"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Detalhes do Livro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/img_livro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_titulo_livro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Título:"
        android:textSize="22sp"
        android:textColor="#4E342E"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo_pagina"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_autor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Autor:"
        android:textSize="22sp"
        android:textColor="#4E342E"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo_livro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>