<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F6">

    <TextView
        android:id="@+id/txt_titulo_pagina"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalhes do Livro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E91E63"
        android:layout_marginTop="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_titulo_livro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Título:"
        android:textSize="22sp"
        android:textColor="#880E4F"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo_pagina"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_autor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Autor:"
        android:textSize="22sp"
        android:textColor="#880E4F"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo_livro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>